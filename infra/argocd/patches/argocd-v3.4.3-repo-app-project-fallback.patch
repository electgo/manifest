+func (s *Server) getRepoWithEffectiveProject(ctx context.Context, url, project string) (*v1alpha1.Repository, string, error) {
+	repo, err := s.getRepo(ctx, url, project)
+	if project != "" {
+		return repo, project, err
+	}
+	if err == nil && repo.Project != "" {
+		return repo, repo.Project, nil
+	}
+
+	repos, listErr := s.db.ListRepositories(ctx)
+	if listErr != nil {
+		if err != nil {
+			return nil, "", err
+		}
+		return repo, project, nil
+	}
+	for _, candidate := range repos {
+		if !git.SameURL(candidate.Repo, url) {
+			continue
+		}
+		if !s.enf.Enforce(ctx.Value("claims"), rbac.ResourceRepositories, rbac.ActionGet, createRBACObject(candidate.Project, candidate.Repo)) {
+			continue
+		}
+		resolvedRepo, resolvedErr := s.getRepo(ctx, url, candidate.Project)
+		if resolvedErr != nil {
+			return nil, "", resolvedErr
+		}
+		return resolvedRepo, candidate.Project, nil
+	}
+	if err != nil {
+		return nil, "", err
+	}
+	return repo, project, nil
+}
