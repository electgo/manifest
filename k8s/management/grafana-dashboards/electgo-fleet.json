{
 "dashboard": {
  "uid": "electgo-fleet",
  "title": "ElectGo Fleet Overview",
  "tags": [
   "electgo",
   "fleet"
  ],
  "timezone": "browser",
  "refresh": "1m",
  "time": {
   "from": "now-6h",
   "to": "now"
  },
  "panels": [
   {
    "id": 1,
    "type": "row",
    "title": "Fleet at a glance",
    "gridPos": {
     "x": 0,
     "y": 0,
     "w": 24,
     "h": 1
    },
    "collapsed": false,
    "panels": []
   },
   {
    "id": 2,
    "type": "stat",
    "title": "production / nodes ready",
    "gridPos": {
     "x": 0,
     "y": 1,
     "w": 2,
     "h": 4
    },
    "datasource": {
     "type": "prometheus",
     "uid": "prometheus"
    },
    "fieldConfig": {
     "defaults": {
      "unit": "none",
      "thresholds": {
       "mode": "absolute",
       "steps": [
        {
         "color": "green",
         "value": null
        }
       ]
      }
     },
     "overrides": []
    },
    "options": {
     "reduceOptions": {
      "calcs": [
       "lastNotNull"
      ]
     },
     "graphMode": "none",
     "colorMode": "value"
    },
    "targets": [
     {
      "refId": "A",
      "expr": "sum(kube_node_status_condition{condition=\"Ready\",status=\"true\"})",
      "instant": true,
      "datasource": {
       "type": "prometheus",
       "uid": "prometheus"
      }
     }
    ]
   },
