      "refId": "A",
      "expr": "100*sum(container_memory_working_set_bytes{cluster=\"development\",namespace=\"$app\",container!=\"\"})/sum(kube_pod_container_resource_limits{cluster=\"development\",namespace=\"$app\",resource=\"memory\"})",
