{
 "dashboard": {
  "uid": "electgo-dev-app-detail",
  "title": "ElectGo Development / App Detail",
  "tags": [
   "electgo",
   "development",
   "apps"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
   "from": "now-6h",
   "to": "now"
  },
  "templating": {
   "list": [
    {
     "name": "project",
     "type": "custom",
     "query": "product : n8n|pim-bucket-upload|pim-chatbot|pim-master|pim-partners-bundling|pim-sku-finder|pim-websocket|product-ai-enrich, marketplace : crawler-tool|electgo-backroom-fe|electgo-be-point-reward|electgo-be-product|electgo-be-report|electgo-be-sales|electgo-be-user|electgo-be-utils|electgo-frontend|electgo-seller-center, chatbot : etools-chatbot-be",
     "current": {
      "text": "product",
      "value": "n8n|pim-bucket-upload|pim-chatbot|pim-master|pim-partners-bundling|pim-sku-finder|pim-websocket|product-ai-enrich"
     },
     "includeAll": false,
     "multi": false,
     "label": "Project",
     "options": [
      {
       "selected": true,
       "text": "product",
       "value": "n8n|pim-bucket-upload|pim-chatbot|pim-master|pim-partners-bundling|pim-sku-finder|pim-websocket|product-ai-enrich"
      },
      {
       "selected": false,
       "text": "marketplace",
       "value": "crawler-tool|electgo-backroom-fe|electgo-be-point-reward|electgo-be-product|electgo-be-report|electgo-be-sales|electgo-be-user|electgo-be-utils|electgo-frontend|electgo-seller-center"
      },
      {
       "selected": false,
       "text": "chatbot",
       "value": "etools-chatbot-be"
      }
     ]
    },
    {
     "name": "app",
     "type": "query",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "refresh": 2,
     "query": "label_values(kube_pod_info{cluster=\"development\",namespace=~\"${project:raw}\"}, namespace)",
     "current": {
      "text": "pim-master",
      "value": "pim-master"
     },
     "includeAll": false,
     "multi": false,
     "label": "App"
    },
    {
     "name": "pod",
     "type": "query",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "refresh": 2,
     "query": "label_values(kube_pod_info{cluster=\"development\",namespace=\"$app\"}, pod)",
     "current": {
      "text": "All",
      "value": ".*"
     },
     "includeAll": true,
     "allValue": ".*",
     "multi": false,
     "label": "Pod"
    },
    {
     "name": "container",
     "type": "query",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "refresh": 2,
     "query": "label_values(kube_pod_container_info{cluster=\"development\",namespace=\"$app\",pod=~\"${pod:raw}\",container!=\"\"}, container)",
     "current": {
      "text": "All",
      "value": ".*"
     },
     "includeAll": true,
     "allValue": ".*",
     "multi": false,
     "label": "Container"
    }
   ]
  },
  "panels": [
   {
    "id": 1,
    "type": "stat",
    "title": "Pods running",
    "gridPos": {
     "x": 0,
     "y": 0,
     "w": 3,
     "h": 4
    },
    "datasource": {
     "type": "prometheus",
     "uid": "prometheus"
    },
    "fieldConfig": {
     "defaults": {
      "unit": "none",
      "thresholds": {
       "mode": "absolute",
       "steps": [
        {
         "color": "green",
         "value": null
        }
       ]
      },
      "decimals": 0
     },
     "overrides": []
    },
    "options": {
     "reduceOptions": {
      "calcs": [
       "lastNotNull"
      ]
     },
     "graphMode": "area",
     "colorMode": "value"
    },
    "targets": [
     {
      "refId": "A",
      "expr": "sum(kube_pod_status_phase{cluster=\"development\",namespace=\"$app\",phase=\"Running\"})",
      "instant": true,
      "datasource": {
       "type": "prometheus",
       "uid": "prometheus"
      }
     }
    ]
   },
   {
    "id": 2,
    "type": "stat",
    "title": "Pods not running",
    "gridPos": {
     "x": 3,
     "y": 0,
     "w": 3,
     "h": 4
    },
    "datasource": {
     "type": "prometheus",
     "uid": "prometheus"
    },
    "fieldConfig": {
     "defaults": {
      "unit": "none",
      "thresholds": {
       "mode": "absolute",
       "steps": [
        {
         "color": "green",
         "value": null
        },
        {
         "color": "red",
         "value": 1
        }
       ]
      },
      "decimals": 0
     },
     "overrides": []
    },
    "options": {
     "reduceOptions": {
      "calcs": [
       "lastNotNull"
      ]
     },
     "graphMode": "area",
     "colorMode": "value"
    },
    "targets": [
     {
      "refId": "A",
      "expr": "sum(kube_pod_status_phase{cluster=\"development\",namespace=\"$app\",phase=~\"Pending|Failed|Unknown\"})",
      "instant": true,
      "datasource": {
       "type": "prometheus",
       "uid": "prometheus"
      }
     }
    ]
   },
   {
